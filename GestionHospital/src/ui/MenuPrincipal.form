<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.MenuPrincipal">
  <grid id="menuRoot" binding="panel1" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="8" vgap="8">
    <margin top="12" left="12" bottom="12" right="12"/>
    <constraints>
      <xy x="20" y="20" width="420" height="220"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="lblTitulo" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Seleccione una opcion"/>
        </properties>
      </component>
      <component id="cbMenu" class="javax.swing.JComboBox" binding="cbOpciones">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <model>
            <item value="Simulacion hospital"/>
            <item value="Consultar pabellon por EPS"/>
          </model>
        </properties>
      </component>
      <component id="btnAbrirMenu" class="javax.swing.JButton" binding="btnAbrir">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Abrir"/>
        </properties>
      </component>
      <vspacer id="menuSpace">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
    </children>
  </grid>
</form>
