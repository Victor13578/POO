<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.InterfazPabellon">
  <grid id="pabellonRoot" binding="panel1" layout-manager="GridLayoutManager" row-count="5" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="8" vgap="8">
    <margin top="12" left="12" bottom="12" right="12"/>
    <constraints>
      <xy x="20" y="20" width="460" height="210"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="lblEps" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="EPS:"/>
        </properties>
      </component>
      <component id="txtEpsField" class="javax.swing.JTextField" binding="txtEps">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Sura"/>
        </properties>
      </component>
      <component id="lblResultado" class="javax.swing.JLabel">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Pabellon:"/>
        </properties>
      </component>
      <component id="txtResultadoField" class="javax.swing.JTextField" binding="txtResultado">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <editable value="false"/>
        </properties>
      </component>
      <component id="btnConsultarPabellon" class="javax.swing.JButton" binding="btnConsultar">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Consultar"/>
        </properties>
      </component>
      <component id="btnLimpiarPabellon" class="javax.swing.JButton" binding="btnLimpiar">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Limpiar"/>
        </properties>
      </component>
      <component id="btnVolverPabellon" class="javax.swing.JButton" binding="btnVolver">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Volver"/>
        </properties>
      </component>
      <vspacer id="pabellonSpace">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="2" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
    </children>
  </grid>
</form>
