              </component>
              <component id="fieldSintoma" class="javax.swing.JTextField" binding="txtSintoma">
                <constraints>
                  <grid row="5" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="infarto"/>
