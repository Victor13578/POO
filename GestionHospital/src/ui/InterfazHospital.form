<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.InterfazHospital">
  <grid id="27dc6" binding="panel1" layout-manager="BorderLayout" hgap="10" vgap="10">
    <constraints>
      <xy x="20" y="20" width="760" height="520"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="topPanel" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="8" vgap="8">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="formPanel" layout-manager="GridLayoutManager" row-count="7" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="8" vgap="8">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <foreground color="-10888891"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="lblNombreMedico" class="javax.swing.JLabel">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Nombre medico:"/>
                </properties>
              </component>
              <component id="fieldNombreMedico" class="javax.swing.JTextField" binding="txtNombreMedico">
